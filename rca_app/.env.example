# ── Local development ─────────────────────────────────────────────
# Databricks CLI profile for authentication (must exist in ~/.databrickscfg)
DATABRICKS_PROFILE=DEFAULT

# ── Data location ────────────────────────────────────────────────
CATALOG=bx4
SCHEMA=eo_analytics_plane

# ── SQL Warehouse ────────────────────────────────────────────────
# Explicit warehouse ID (optional — auto-discovers a running serverless warehouse if blank)
DATABRICKS_WAREHOUSE_ID=

# ── AI / Genie ───────────────────────────────────────────────────
# Foundation Model API serving endpoint name (model name, not full URL)
SERVING_ENDPOINT=databricks-claude-sonnet-4

# Genie Space ID for natural-language Q&A (leave blank to use SQL fallback)
GENIE_SPACE_ID=

# ── Lakebase PostgreSQL ──────────────────────────────────────────
# Lakebase host DNS (auto-discovered from instance name if blank)
LAKEBASE_HOST=
# PostgreSQL database name (default: databricks_postgres)
LAKEBASE_DATABASE=databricks_postgres
# Lakebase instance name for OAuth credential generation
LAKEBASE_INSTANCE_NAME=jnj-eo-analytics-demo

# ── Deployment only (used by databricks.yml / deploy_with_env.sh) ─
APP_NAME=jnj-eo-analytics-demo
VOLUME=raw_landing
TABLE=
VS_INDEX=
DATABRICKS_TOKEN=
